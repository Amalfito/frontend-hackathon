# Copie ce fichier en .env.local puis renseigne les valeurs depuis
# Supabase → Project Settings → Data API / API Keys.

# URL du projet (ex: https://xxxxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Clé "anon public" — exposée au navigateur, lecture seule via RLS
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Clé "service_role" — SECRÈTE, serveur uniquement. Bypasse la RLS.
# Ne jamais préfixer avec NEXT_PUBLIC_ ni committer.
SUPABASE_SERVICE_ROLE_KEY=

# Clé d'accès au tableau de bord /admin (choisis une valeur secrète)
ADMIN_KEY=change-me
